<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fashion.mapper.CategoryMapper">
    <!-- 条件查询 -->
    <select id="selectByCondition" resultType="com.fashion.entity.Category">
        select * from category
        <where>
            <if test="params.name != null and params.name != ''">
                and name like concat('%', #{params.name}, '%')
            </if>
            <if test="params.type != null">
                and type = #{params.type}
            </if>
            <if test="params.status != null">
                and status = #{params.status}
            </if>
        </where>
        order by sort desc
    </select>
    
    <!-- 获取所有分类 -->
    <select id="list" resultType="com.fashion.entity.Category">
        select * from category order by sort desc
    </select>
    
    <!-- 根据类型查询分类 -->
    <select id="listByType" resultType="com.fashion.entity.Category">
        select * from category
        <where>
            <if test="type != null">
                and type = #{type}
            </if>
        </where>
        order by sort desc
    </select>
    <select id="selectById" resultType="com.fashion.entity.Category" parameterType="java.lang.Long">
        select * from category where id = #{id}
    </select>

    <!-- 新增分类 -->
    <insert id="save" parameterType="com.fashion.entity.Category" useGeneratedKeys="true" keyProperty="id">
        insert into category(name, type, sort, status, create_time, update_time, create_user, update_user)
        values(#{name}, #{type}, #{sort}, #{status}, #{createTime}, #{updateTime}, #{createUser}, #{updateUser})
    </insert>
    
    <!-- 更新分类 -->
    <update id="update" parameterType="com.fashion.entity.Category">
        update category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="type != null">type = #{type},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateUser != null">update_user = #{updateUser},</if>
        </set>
        where id = #{id}
    </update>
    
    <!-- 删除分类 -->
    <delete id="deleteById">
        delete from category where id = #{id}
    </delete>
</mapper>
